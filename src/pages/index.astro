---
import Layout from '../layouts/Layout.astro';
import members from '../data/members.json';
import events from '../data/events.json';
import resources from '../data/resources.json';

function formatDate(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Layout title="Sac AI Hub — Sacramento AI Collective">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-tag">Sacramento, California</div>
    <h1>Where <em>Sacramento</em><br/>builds with AI.</h1>
    <p>A community hub for local AI builders, researchers, and curious minds. Open source, community maintained.</p>
    <div class="hero-actions">
      <a href="https://github.com/zenpierce27/sac-ai-hub" target="_blank" class="btn-primary">Contribute on GitHub</a>
      <a href="#members" class="btn-secondary">Meet the Community</a>
    </div>
  </div>

  <!-- MEMBERS -->
  <section id="members">
    <div class="section-header">
      <h2>Members</h2>
      <span>{members.length} listed</span>
    </div>
    <div class="grid">
      {members.map(m => (
        <div class="card">
          <div class="card-label">Member</div>
          <h3>{m.name}</h3>
          <p class="event-date">{m.role}</p>
          <p>{m.bio}</p>
          <div class="card-tags">
            {m.tags.map(t => <span class="tag">{t}</span>)}
          </div>
          {m.github && <a href={m.github} class="card-link" target="_blank">GitHub →</a>}
        </div>
      ))}
      <div class="card" style="display:flex;align-items:center;justify-content:center;min-height:160px;">
        <a href="https://github.com/zenpierce27/sac-ai-hub/blob/main/CONTRIBUTING.md" class="card-link" target="_blank">+ Add yourself →</a>
      </div>
    </div>
  </section>

  <!-- EVENTS -->
  <section id="events">
    <div class="section-header">
      <h2>Events</h2>
      <span>{events.length} upcoming</span>
    </div>
    <div class="grid">
      {events.map(e => (
        <div class="card">
          <div class="card-label">Event</div>
          <div class="event-date">{formatDate(e.date)} · {e.time} · {e.location}</div>
          <h3>{e.title}</h3>
          <p>{e.description}</p>
          {e.link && <a href={e.link} class="card-link" target="_blank">Details →</a>}
        </div>
      ))}
      <div class="card" style="display:flex;align-items:center;justify-content:center;min-height:140px;">
        <a href="https://github.com/zenpierce27/sac-ai-hub/blob/main/CONTRIBUTING.md" class="card-link" target="_blank">+ Add an event →</a>
      </div>
    </div>
  </section>

  <!-- RESOURCES -->
  <section id="resources">
    <div class="section-header">
      <h2>Resources</h2>
      <span>{resources.length} links</span>
    </div>
    <div class="grid">
      {resources.map(r => (
        <div class="card">
          <div class="card-label">{r.category}</div>
          <h3>{r.title}</h3>
          <p>{r.description}</p>
          <a href={r.url} class="card-link" target="_blank">Visit →</a>
        </div>
      ))}
      <div class="card" style="display:flex;align-items:center;justify-content:center;min-height:140px;">
        <a href="https://github.com/zenpierce27/sac-ai-hub/blob/main/CONTRIBUTING.md" class="card-link" target="_blank">+ Add a resource →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="cta">
    <h2>This site is built by the<br/><span>community, for the community.</span></h2>
    <a href="https://github.com/zenpierce27/sac-ai-hub" target="_blank" class="btn-primary">Fork it on GitHub</a>
  </div>

</Layout>
